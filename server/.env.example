# Copy to .env and adjust to your local MySQL instance.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=umatroot
DB_NAME=umat_complaints_db

# Secret used to sign JWTs. Change this in any real deployment.
JWT_SECRET=umat-dev-secret-change-me
JWT_EXPIRES_IN=12h

# API server port
PORT=4000

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGIN=http://localhost:8085,http://127.0.0.1:8085
